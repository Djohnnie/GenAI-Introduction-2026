@* The root HTML document. Every Blazor page is rendered inside this shell. *@
<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <base href="/" />
    <ResourcePreloader />
    @* MudBlazor uses the Roboto font (Material Design). *@
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css?family=Roboto:300,400,500,700&display=swap" rel="stylesheet" />
    @* MudBlazor's stylesheet ships inside the NuGet package; _content/...
       is how static files from a Razor class library are served. *@
    <link href="_content/MudBlazor/MudBlazor.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="@Assets["app.css"]" />
    <link rel="stylesheet" href="@Assets["DocumentIntelligence.Poc.styles.css"]" />
    <ImportMap />
    @* @rendermode InteractiveServer: the UI is interactive over a SignalR
       connection instead of static server-side rendering. *@
    <HeadOutlet @rendermode="InteractiveServer" />
</head>

<body>
    <Routes @rendermode="InteractiveServer" />
    <ReconnectModal />
    @* MudBlazor's JavaScript (popover positioning, scroll handling, ...). *@
    <script src="_content/MudBlazor/MudBlazor.min.js"></script>
    <script src="@Assets["_framework/blazor.web.js"]"></script>
</body>

</html>
