@* The overview page: lists all purchase orders and offers two ways to create
   a new one — an empty form, or extraction from an uploaded document. *@

@* @page makes this component routable: it answers on "/". *@
@page "/"

@* @inject pulls services out of the DI container (see Program.cs). *@
@inject PurchaseOrderStore Store
@inject ISnackbar Snackbar
@inject ContentUnderstandingService ContentUnderstanding
@inject PurchaseOrderDraft Draft
@inject NavigationManager Navigation
@inject ILogger<Home> Logger

<PageTitle>Purchase Orders</PageTitle>

@* Page header: title on the left, action buttons on the right.
   MudSpacer pushes everything after it to the right edge. *@
<MudStack Row AlignItems="AlignItems.Center" Class="mb-6">
    <div>
        <MudText Typo="Typo.h4" Style="font-weight: 600;">Purchase Orders</MudText>
        <MudText Typo="Typo.body2" Color="Color.Secondary">
            Manage purchase orders for the Content Understanding demo.
        </MudText>
    </div>
    <MudSpacer />
    <MudButton Variant="Variant.Outlined"
               Color="Color.Primary"
               StartIcon="@Icons.Material.Outlined.DocumentScanner"
               Disabled="_analyzing"
               OnClick="OpenDocumentPicker">
        New from document
    </MudButton>
    <MudButton Variant="Variant.Filled"
               Color="Color.Primary"
               DropShadow="false"
               StartIcon="@Icons.Material.Filled.Add"
               Href="/purchase-orders/new">
        New purchase order
    </MudButton>
</MudStack>

@* The file upload lives OUTSIDE the header stack and is invisible (d-none):
   it only hosts the hidden <input type="file">. The button above opens the
   file picker through a @ref call — this keeps the header layout clean,
   because MudFileUpload's wrapper div doesn't align well inside a MudStack. *@
<MudFileUpload T="IBrowserFile"
               @ref="_fileUpload"
               FilesChanged="CreateFromDocument"
               Accept=".pdf,.jpg,.jpeg,.png,.tif,.tiff"
               Class="d-none" />

@* Full-screen overlay shown while the document is being analyzed in Azure.
   Analysis takes a few seconds, so feedback is essential. *@
<MudOverlay Visible="_analyzing" DarkBackground Absolute="false" ZIndex="1400">
    <MudStack AlignItems="AlignItems.Center" Spacing="3">
        <MudProgressCircular Indeterminate Color="Color.Primary" Size="Size.Large" />
        <MudText Typo="Typo.subtitle1" Style="color: white;">Analyzing document with Azure Content Understanding…</MudText>
    </MudStack>
</MudOverlay>

@if (_orders.Count == 0)
{
    @* Empty state: friendlier than an empty table. *@
    <MudPaper Outlined Class="pa-12 d-flex flex-column align-center">
        <MudIcon Icon="@Icons.Material.Outlined.ReceiptLong" Size="Size.Large" Color="Color.Secondary" Class="mb-3" />
        <MudText Typo="Typo.h6" Class="mb-1">No purchase orders yet</MudText>
        <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-4">
            Data is kept in memory and is lost when the application restarts.
        </MudText>
        <MudButton Variant="Variant.Outlined"
                   Color="Color.Primary"
                   StartIcon="@Icons.Material.Filled.Add"
                   Href="/purchase-orders/new">
            Create your first purchase order
        </MudButton>
    </MudPaper>
}
else
{
    <MudPaper Outlined>
        @* MudTable renders one row per item; inside RowTemplate, "context"
           refers to the current PurchaseOrder. *@
        <MudTable Items="_orders" Hover Elevation="0">
            <HeaderContent>
                <MudTh>PO number</MudTh>
                <MudTh>Vendor</MudTh>
                <MudTh>Description</MudTh>
                <MudTh Style="text-align:right">Lines</MudTh>
                <MudTh Style="text-align:right">Total (excl. VAT)</MudTh>
                <MudTh Style="text-align:right">Total (incl. VAT)</MudTh>
                <MudTh />
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="PO number">
                    <MudText Typo="Typo.body2" Style="font-weight: 600;">@context.PoNumber</MudText>
                </MudTd>
                <MudTd DataLabel="Vendor">@context.VendorName</MudTd>
                <MudTd DataLabel="Description">@context.Description</MudTd>
                <MudTd DataLabel="Lines" Style="text-align:right">@context.Lines.Count</MudTd>
                <MudTd DataLabel="Total (excl. VAT)" Style="text-align:right">@context.TotalAmount.ToString("C2")</MudTd>
                <MudTd DataLabel="Total (incl. VAT)" Style="text-align:right">
                    <MudText Typo="Typo.body2" Style="font-weight: 600;">@context.TotalAmountIncludingVat.ToString("C2")</MudText>
                </MudTd>
                <MudTd Style="text-align:right">
                    <MudIconButton Icon="@Icons.Material.Outlined.Edit"
                                   Size="Size.Small"
                                   Href="@($"/purchase-orders/{context.Id}")"
                                   aria-label="Edit" />
                    <MudIconButton Icon="@Icons.Material.Outlined.Delete"
                                   Size="Size.Small"
                                   Color="Color.Error"
                                   OnClick="@(() => Delete(context))"
                                   aria-label="Delete" />
                </MudTd>
            </RowTemplate>
        </MudTable>
    </MudPaper>
}

@code {
    // Browsers can upload huge files; cap the stream at 20 MB to protect the
    // server. OpenReadStream throws when the file is larger.
    private const long MaxUploadSizeBytes = 20 * 1024 * 1024;

    private IReadOnlyList<PurchaseOrder> _orders = [];
    private MudFileUpload<IBrowserFile>? _fileUpload;
    private bool _analyzing;

    // Lifecycle method: runs once when the component is created.
    protected override void OnInitialized()
    {
        _orders = Store.GetAll();
    }

    // Forwards the button click to the hidden file input.
    private Task OpenDocumentPicker()
        => _fileUpload?.OpenFilePickerAsync() ?? Task.CompletedTask;

    private void Delete(PurchaseOrder order)
    {
        Store.Delete(order.Id);
        _orders = Store.GetAll(); // refresh the local snapshot
        Snackbar.Add($"Purchase order '{order.PoNumber}' deleted.", Severity.Success);
    }

    // Runs when the user picked a file. Flow:
    // browser -> temp file on the server -> Azure analysis -> draft -> edit form.
    private async Task CreateFromDocument(IBrowserFile? file)
    {
        if (file is null)
        {
            return;
        }

        if (!ContentUnderstanding.IsConfigured)
        {
            Snackbar.Add("Azure Content Understanding is not configured. Set CONTENT_UNDERSTANDING_ENDPOINT and CONTENT_UNDERSTANDING_KEY in launchSettings.json.", Severity.Warning);
            return;
        }

        _analyzing = true;
        string? tempFilePath = null;
        try
        {
            // IBrowserFile streams from the browser over the SignalR
            // connection — it can only be read once and has no length-known
            // seekable stream. Buffering it to a temp file first gives us a
            // stable copy to send to Azure.
            var tempFolder = Path.Combine(Path.GetTempPath(), "ContentUnderstandingPoc");
            Directory.CreateDirectory(tempFolder);
            tempFilePath = Path.Combine(tempFolder, $"{Guid.NewGuid():N}{Path.GetExtension(file.Name)}");

            await using (var target = File.Create(tempFilePath))
            {
                await file.OpenReadStream(MaxUploadSizeBytes).CopyToAsync(target);
            }

            var contentType = string.IsNullOrWhiteSpace(file.ContentType) ? "application/octet-stream" : file.ContentType;
            var order = await ContentUnderstanding.AnalyzePurchaseOrderAsync(tempFilePath, contentType);

            // Stash the result in the scoped draft service and navigate; the
            // edit form picks it up so the user can review before saving.
            Draft.Set(order);
            Snackbar.Add($"Document '{file.Name}' analyzed. Review the extracted purchase order and save it.", Severity.Success);
            Navigation.NavigateTo("/purchase-orders/new");
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to analyze document {FileName}.", file.Name);
            Snackbar.Add($"Failed to analyze document: {ex.Message}", Severity.Error);
        }
        finally
        {
            // Always remove the temp file, also when analysis failed.
            if (tempFilePath is not null)
            {
                try { File.Delete(tempFilePath); } catch { /* best effort cleanup */ }
            }
            _analyzing = false;
        }
    }
}
